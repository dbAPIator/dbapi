# Copy to .env and adjust before: docker compose up -d

# --- dbAPI image (pin a release tag in production) ---
DBAPI_IMAGE_TAG=1.2.5
DBAPI_PORT=8888
DBAPI_BASE_URL=http://localhost:8888

# single = one auto-provisioned API at /v1/data/... (recommended for most apps)
# multi  = create APIs via Management API at /v1/apis/{apiId}/data/...
DEPLOYMENT_MODE=single

CONFIG_API_SECRET=change-me-in-production
CONFIG_API_IPS_ACLS=[{"allow":true,"ip":"0.0.0.0/0"}]

# --- Database (bundled MariaDB service) ---
DB_HOST=mysql
DB_PORT=3306
MYSQL_DATABASE=myapp
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=rootpassword
MARIADB_TAG=11

# --- Optional API metadata (single-mode, written on first provision) ---
API_TITLE=My App API
API_DESCRIPTION=
API_VERSION=1.0.0

# --- Redis (webhooks; optional but included in this stack) ---
REDIS_TAG=7
REDIS_STREAM=dbapi_webhooks
REDIS_GROUP=dbapi_webhooks_group
# REDIS_PASSWORD=
# REDIS_USER=

# --- Pagination defaults ---
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=1000
DEFAULT_RELATIONSHIPS_PAGE_SIZE=10

# --- Optional tools profile (docker compose --profile tools up -d) ---
ADMINER_PORT=8889
