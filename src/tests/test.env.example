# Copy to tests/test.env (loaded automatically by PHPUnit bootstrap).
#
# Integration tests need PHP 8.3+, ext-yaml, and a running web server at BASE_URL.
# Local built-in server (from repo root):
#   CONFIGS_DIR=/tmp/phpunit-configs DEPLOYMENT_MODE=multi \
#   CONFIG_API_SECRET=myverysecuresecret \
#   CONFIG_API_IPS_ACLS='[{"allow":true,"ip":"0.0.0.0/0"}]' \
#   php -S 127.0.0.1:8080 -t src/public src/public/ci-router.php
#
# Docker (PHP 8.3): bash scripts/run-phpunit-docker.sh
BASE_URL=http://127.0.0.1:8080/
MGMT_KEY=myverysecuresecret

DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=dbapi
DB_PASS=dbapi
DB_NAME=dbapi_dataplane
