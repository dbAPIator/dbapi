{
    "require": {
        "firebase/php-jwt": "^7.0",
        "ext-json": "*",
        "ext-yaml": "*",
        "predis/predis": "^2.3",
        "guzzlehttp/guzzle": "^7.9",
        "ext-curl": "*",
        "opis/json-schema": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "*"
    },
    "scripts": {
        "test": "phpunit --testsuite dbapi",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:dataplane-setup": [
            "bash ../scripts/load-dataplane-schema-local.sh",
            "cp -n tests/connection.dataplane.example.json tests/connection.json || true",
            "cp -n tests/test.env.dataplane.example tests/test.env || true"
        ],
        "check:dataplane-schema": "bash ../scripts/check-dataplane-schema-sync.sh"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        }
    }
}
